<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Cercle extérieur -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#26D0CE" />
            <size
                    android:width="120dp"
                    android:height="120dp" />
        </shape>
    </item>
    <!-- Cercle intérieur -->
    <item
            android:top="12dp"
            android:bottom="12dp"
            android:left="12dp"
            android:right="12dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <!-- Centre (triangle taxi simplifié) -->
    <item
            android:gravity="center">
        <shape android:shape="rectangle">
            <solid android:color="#26D0CE" />
            <size
                    android:width="40dp"
                    android:height="40dp" />
        </shape>
    </item>
</layer-list>