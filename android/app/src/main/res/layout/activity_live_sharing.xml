<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              xmlns:app="http://schemas.android.com/apk/res-auto"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:orientation="vertical"
              android:background="#F5F5F5">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#FF6F00"
            app:titleTextColor="@android:color/white"
            app:title="📍 Partage de trajet" />

    <!-- Carte -->
    <fragment
            android:id="@+id/map"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="300dp" />

    <!-- Informations de partage -->
    <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

            <!-- Titre avec fond orange et texte blanc -->
            <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#FF6F00">

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🔗 Partager ce trajet"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:padding="12dp"
                        android:gravity="center" />

            </androidx.cardview.widget.CardView>

            <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginVertical="12dp" />

            <!-- Code de partage -->
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Code de suivi :"
                    android:textSize="14sp"
                    android:textColor="#666666" />

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                <TextView
                        android:id="@+id/tvShareCode"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="XXXXXX"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:textColor="#2196F3"
                        android:fontFamily="monospace"
                        android:background="#F0F0F0"
                        android:padding="12dp"
                        android:gravity="center" />

                <Button
                        android:id="@+id/btnCopyCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Copier"
                        android:layout_marginStart="8dp"
                        style="@style/Widget.Material3.Button.OutlinedButton" />
            </LinearLayout>

            <!-- Lien de partage -->
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lien de suivi :"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginTop="16dp" />

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                <TextView
                        android:id="@+id/tvShareLink"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="https://..."
                        android:textSize="12sp"
                        android:textColor="#666666"
                        android:background="#F0F0F0"
                        android:padding="12dp"
                        android:maxLines="1"
                        android:ellipsize="end" />

                <Button
                        android:id="@+id/btnCopyLink"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Copier"
                        android:layout_marginStart="8dp"
                        style="@style/Widget.Material3.Button.OutlinedButton" />
            </LinearLayout>

            <!-- Statut et compteur -->
            <TextView
                    android:id="@+id/tvTripStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔄 Activation du partage..."
                    android:textSize="14sp"
                    android:padding="12dp"
                    android:background="#FFF3E0"
                    android:layout_marginTop="16dp"
                    android:gravity="center" />

            <TextView
                    android:id="@+id/tvViewerCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="👁️ 0 personne suit votre trajet"
                    android:textSize="14sp"
                    android:textColor="#666666"
                    android:layout_marginTop="8dp"
                    android:gravity="center" />

            <!-- Boutons d'action -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp">

                <Button
                        android:id="@+id/btnShareWhatsApp"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📱 WhatsApp"
                        android:layout_marginEnd="8dp"
                        style="@style/Widget.Material3.Button" />

                <Button
                        android:id="@+id/btnStopSharing"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⏹️ Arrêter"
                        android:layout_marginStart="8dp"
                        style="@style/Widget.Material3.Button.TextButton" />
            </LinearLayout>

            <!-- Bouton simulateur (pour tester sans GPS) -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                <Button
                        android:id="@+id/btnSimulate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📍 Simuler position (test)"
                        android:backgroundTint="#FF9800"
                        style="@style/Widget.Material3.Button" />

            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone" />

</LinearLayout>