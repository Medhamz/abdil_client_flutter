<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              xmlns:app="http://schemas.android.com/apk/res-auto"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:orientation="vertical"
              android:background="#0a0a0a">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_gradient_header"
            android:padding="24dp"
            android:paddingTop="48dp">

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="❓ Aide"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#00d4ff" />

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tout ce que vous devez savoir"
                android:textSize="12sp"
                android:textColor="#88FFFFFF" />

    </LinearLayout>

    <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <!-- Message d'accueil -->
            <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    android:layout_marginBottom="20dp"
                    app:cardBackgroundColor="#1a1a3e">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                    <TextView
                            android:id="@+id/tvWelcome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👋 Bonjour"
                            android:textSize="16sp"
                            android:textColor="#ffffff"
                            android:textStyle="bold" />

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Posez votre question ou parcourez les rubriques ci-dessous."
                            android:textSize="13sp"
                            android:textColor="#aaaaaa"
                            android:layout_marginTop="4dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Recherche -->
            <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    android:layout_marginBottom="16dp"
                    app:cardBackgroundColor="#0f1322">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                    <SearchView
                            android:id="@+id/searchView"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:queryHint="🔍 Rechercher une aide..."
                            android:background="@drawable/search_view_bg"
                            app:searchIcon="@null"
                            app:queryBackground="@null" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Boutons rapides -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                <Button
                        android:id="@+id/btnFaq"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="📋 FAQ"
                        android:textSize="11sp"
                        android:textColor="#ffffff"
                        android:backgroundTint="#3498DB"
                        android:layout_marginEnd="4dp" />

                <Button
                        android:id="@+id/btnSupport"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="📞 Support"
                        android:textSize="11sp"
                        android:textColor="#ffffff"
                        android:backgroundTint="#9C27B0"
                        android:layout_marginEnd="4dp" />

                <Button
                        android:id="@+id/btnTutorial"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="🎓 Tutoriel"
                        android:textSize="11sp"
                        android:textColor="#ffffff"
                        android:backgroundTint="#00d4ff" />

            </LinearLayout>

            <!-- Liste des aides -->
            <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvHelpItems"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>