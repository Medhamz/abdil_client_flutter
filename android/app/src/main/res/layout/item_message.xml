<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
             xmlns:app="http://schemas.android.com/apk/res-auto"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:padding="4dp">

    <!-- Message reçu (de l'autre personne) -->
    <LinearLayout
            android:id="@+id/layout_other"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:orientation="vertical"
            android:maxWidth="280dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="8dp"
            android:visibility="gone">

        <!-- Nom de l'expéditeur -->
        <TextView
                android:id="@+id/tvSenderName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chauffeur"
                android:textSize="11sp"
                android:textColor="#009688"
                android:textStyle="bold"
                android:layout_marginStart="12dp"
                android:layout_marginBottom="2dp" />

        <!-- Image pour les messages reçus (AJUSTÉ) -->
        <ImageView
                android:id="@+id/ivImageOther"
                android:layout_width="200dp"
                android:layout_height="150dp"
                android:layout_marginTop="4dp"
                android:scaleType="centerCrop"
                android:visibility="gone" />

        <!-- Contenu du message avec CardView -->
        <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_margin="4dp">

            <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_chat_other"
                    android:gravity="center_vertical">

                <TextView
                        android:id="@+id/tvMessageOther"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#2C3E50"
                        android:textSize="14sp"
                        android:lineSpacingExtra="2dp"
                        android:padding="10dp" />

                <ImageButton
                        android:id="@+id/btnPlayVoiceOther"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_media_play"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:visibility="gone" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Heure -->
        <TextView
                android:id="@+id/tvTimeOther"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#95A5A6"
                android:layout_marginTop="2dp"
                android:layout_marginStart="12dp"
                android:gravity="end" />

        <!-- Réaction -->
        <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp"
                android:layout_marginStart="12dp">

            <TextView
                    android:id="@+id/tvReactionOther"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="14sp"
                    android:visibility="gone" />

            <ImageButton
                    android:id="@+id/btnAddReactionOther"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_add"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:visibility="visible" />

        </LinearLayout>

    </LinearLayout>

    <!-- Message envoyé (par moi) -->
    <LinearLayout
            android:id="@+id/layout_mine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:orientation="vertical"
            android:maxWidth="280dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="4dp"
            android:visibility="gone">

        <!-- Image pour les messages envoyés (AJUSTÉ) -->
        <ImageView
                android:id="@+id/ivImageMine"
                android:layout_width="200dp"
                android:layout_height="150dp"
                android:layout_marginTop="4dp"
                android:scaleType="centerCrop"
                android:visibility="gone" />

        <!-- Contenu du message avec CardView -->
        <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                android:layout_margin="4dp">

            <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_chat_mine"
                    android:gravity="center_vertical">

                <TextView
                        android:id="@+id/tvMessageMine"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:lineSpacingExtra="2dp"
                        android:padding="10dp" />

                <ImageButton
                        android:id="@+id/btnPlayVoiceMine"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_media_play"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:visibility="gone" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Ligne : Heure + Statut (vu/délivré) -->
        <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="12dp"
                android:gravity="end">

            <TextView
                    android:id="@+id/tvTimeMine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="#CCFFFFFF" />

            <TextView
                    android:id="@+id/tvStatusMine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✓"
                    android:textSize="10sp"
                    android:textColor="#2C3E50"
                    android:layout_marginStart="4dp"
                    android:visibility="visible" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>