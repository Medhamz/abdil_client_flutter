<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              xmlns:app="http://schemas.android.com/apk/res-auto"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:orientation="vertical"
              android:background="#F5F7FA">

    <!-- Header -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_gradient_header"
            android:padding="20dp"
            android:paddingTop="40dp">

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📜 Historique des courses"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@android:color/white" />

        <TextView
                android:id="@+id/tvClientNameHistory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Client: "
                android:textSize="12sp"
                android:textColor="#CCFFFFFF"
                android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Contenu principal -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

        <!-- Boutons actions -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

            <Button
                    android:id="@+id/btnSelectAll"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="✓ TOUT SÉLECTIONNER"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#3498DB"
                    android:padding="8dp"
                    android:layout_marginEnd="8dp"
                    android:maxLines="2" />

            <Button
                    android:id="@+id/btnDeleteSelected"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="🗑 SUPPRIMER SÉLECTION"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#E74C3C"
                    android:padding="8dp"
                    android:layout_marginStart="8dp"
                    android:maxLines="2" />

        </LinearLayout>

        <!-- RecyclerView pour la liste -->
        <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHistory"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

        <!-- Message si aucune course -->
        <TextView
                android:id="@+id/tvEmptyHistory"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="📭 Aucune course trouvée"
                android:textSize="16sp"
                android:textColor="#7F8C8D"
                android:gravity="center"
                android:visibility="gone" />

    </LinearLayout>

</LinearLayout>