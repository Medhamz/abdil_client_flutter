<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/receipt_background">

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💰 Paiement Crypto"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#00d4ff"
                android:layout_gravity="center"
                android:layout_marginBottom="20dp" />

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

            <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cryptomonnaie:"
                    android:textSize="14sp"
                    android:textColor="#ffffff" />

            <TextView
                    android:id="@+id/tvCryptoCurrency"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="USDT"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#00ff88" />

        </LinearLayout>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

            <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Montant:"
                    android:textSize="14sp"
                    android:textColor="#ffffff" />

            <TextView
                    android:id="@+id/tvCryptoAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 FCFA"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#ffd700" />

        </LinearLayout>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

            <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Réseau:"
                    android:textSize="14sp"
                    android:textColor="#ffffff" />

            <TextView
                    android:id="@+id/tvCryptoNetwork"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TRC20"
                    android:textSize="14sp"
                    android:textColor="#00d4ff" />

        </LinearLayout>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Adresse de réception:"
                android:textSize="12sp"
                android:textColor="#aaaaaa"
                android:layout_marginBottom="8dp" />

        <TextView
                android:id="@+id/tvCryptoAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TXYZ..."
                android:textSize="11sp"
                android:textColor="#00d4ff"
                android:fontFamily="monospace"
                android:background="#1a1a2e"
                android:padding="12dp"
                android:gravity="center"
                android:layout_marginBottom="16dp" />

        <ImageView
                android:id="@+id/ivCryptoQRCode"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp" />

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Envoyez exactement le montant en USDT/BNB/SOL sur cette adresse"
                android:textSize="11sp"
                android:textColor="#ff9800"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

            <Button
                    android:id="@+id/btnCopyAddress"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="📋 Copier"
                    android:textSize="12sp"
                    android:backgroundTint="#2196F3"
                    android:layout_marginEnd="8dp" />

            <Button
                    android:id="@+id/btnCheckPayment"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="✅ Vérifier"
                    android:textSize="12sp"
                    android:backgroundTint="#4CAF50"
                    android:layout_marginEnd="8dp" />

            <Button
                    android:id="@+id/btnCloseCrypto"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="❌ Fermer"
                    android:textSize="12sp"
                    android:backgroundTint="#F44336" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>