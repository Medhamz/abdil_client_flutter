<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
              xmlns:app="http://schemas.android.com/apk/res-auto"
              android:layout_width="match_parent"
              android:layout_height="match_parent"
              android:orientation="vertical"
              android:background="#F5F7FA">

    <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#009688"
            app:titleTextColor="@android:color/white"
            app:title="📅 Programmer une course" />

    <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Date et heure"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#2C3E50"
                    android:layout_marginBottom="8dp" />

            <!-- Utilisation de Button normal au lieu de MaterialDatePicker -->
            <Button
                    android:id="@+id/btnDatePicker"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Sélectionner la date"
                    android:backgroundTint="#E0E0E0"
                    android:textColor="#2C3E50" />

            <Button
                    android:id="@+id/btnTimePicker"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Sélectionner l'heure"
                    android:backgroundTint="#E0E0E0"
                    android:textColor="#2C3E50"
                    android:layout_marginTop="8dp" />

            <TextView
                    android:id="@+id/tvSelectedDateTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:background="#F0F0F0"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:text="Aucune date sélectionnée"
                    android:textColor="#666666" />

            <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginVertical="20dp" />

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Récapitulatif"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#2C3E50"
                    android:layout_marginBottom="12dp" />

            <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                    <TextView
                            android:id="@+id/tvPickupAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Départ: --"
                            android:textSize="14sp" />

                    <TextView
                            android:id="@+id/tvDestinationAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Destination: --"
                            android:textSize="14sp"
                            android:layout_marginTop="8dp" />

                    <TextView
                            android:id="@+id/tvDistance"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Distance: --"
                            android:textSize="14sp"
                            android:layout_marginTop="8dp" />

                    <TextView
                            android:id="@+id/tvPrice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Prix: --"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#009688"
                            android:layout_marginTop="8dp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <Button
                    android:id="@+id/btnSchedule"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="✅ Programmer la course"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#009688"
                    android:layout_marginTop="24dp" />

            <TextView
                    android:id="@+id/tvMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:layout_marginTop="12dp"
                    android:visibility="gone" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>